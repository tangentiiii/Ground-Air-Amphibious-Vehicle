# ============================================================
# STM32CubeIDE / STM32CubeMX common ignores
# 放在 repo/.gitignore
# 适用于 repo/projects/xxx/ 下面的多个 STM32 工程
# ============================================================


# ============================================================
# Build output directories
# ============================================================

**/Debug/
**/Release/
**/build/
**/Build/
**/out/
**/bin/
**/obj/


# ============================================================
# Compiled object / dependency files
# ============================================================

*.o
*.obj
*.d
*.su
*.cyclo
*.lst
*.list
*.map
*.elf
*.axf
*.hex
*.bin
*.srec
*.siz
*.a
*.so
*.dll
*.exe


# ============================================================
# Auto-generated make files from STM32CubeIDE
# ============================================================

**/makefile
**/Makefile
**/objects.mk
**/sources.mk
**/subdir.mk
**/objects.list
*.mk


# ============================================================
# Eclipse / STM32CubeIDE workspace temporary files
# ============================================================

**/.metadata/
**/RemoteSystemsTempFiles/
**/.recommenders/
**/.caches/
**/.cache/


# ============================================================
# Local launch/debug configs
# ============================================================

*.launch


# ============================================================
# STM32CubeIDE local index/settings files
# ============================================================

**/.settings/language.settings.xml
**/.settings/org.eclipse.cdt.core.prefs


# ============================================================
# VS Code local settings
# ============================================================

**/.vscode/
**/.history/


# ============================================================
# OS junk files
# ============================================================

.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini


# ============================================================
# Editor temporary files
# ============================================================

*~
*.swp
*.swo
*.bak
*.tmp
*.temp
*.orig


# ============================================================
# Logs
# ============================================================

*.log


# ============================================================
# Do NOT ignore important STM32 project files
# ============================================================

!**/.project
!**/.cproject
!**/.mxproject
!**/*.ioc
!**/*.ld
!**/Core/
!**/Drivers/
!**/Startup/
!**/README.md
!**/.gitignore